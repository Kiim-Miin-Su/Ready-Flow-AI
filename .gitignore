# envs / caches
.venv/
__pycache__/
*.pyc
.DS_Store
.vercel/
.ipynb_checkpoints/

# raw source data (large; not needed at serve time)
data/

# heavy / regenerable build intermediates (regenerated by build_dataset.py / train.py)
build/*.parquet
build/*.csv
# reference pickle — serving uses build/model_np.json (numpy-only), so the pkl is not deployed
build/*.pkl

# NOTE: build/model_np.json, build/serve_tables.json, build/metrics.json are NOT matched
# by any pattern above, so they ARE committed (required by Vercel includeFiles).

# CLI agent local config
.claude/
