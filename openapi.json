{
  "openapi": "3.1.0",
  "info": {
    "title": "Seoul Flood Risk API",
    "description": "서울 법정동 단위 침수 확률 예측 API.\n\n- 입력: 유저 주소(→법정동) + 실시간 예보 일강우 시퀀스\n- 출력: 침수 확률 `flood_probability` ∈ [0,1]\n- 커버리지: 침수 이력이 있는 93개 법정동 (그 외 404)\n\nFlutter 연동 가이드는 FRONTEND.md 참고.",
    "contact": {
      "name": "doubled_seven"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "헬스체크",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/predict": {
      "post": {
        "tags": [
          "predict"
        ],
        "summary": "침수 확률 예측",
        "description": "주소(또는 adm_cd) + 예보 일강우 → 해당 법정동의 침수 확률.",
        "operationId": "predict_api_predict_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PredictRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PredictResponse"
                }
              }
            }
          },
          "404": {
            "description": "동 미해결/커버리지 밖",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "페이로드 검증 실패"
          }
        }
      }
    },
    "/api/forecast/flood-week": {
      "get": {
        "tags": [
          "forecast"
        ],
        "summary": "향후 7일 침수 확률 예보",
        "description": "기상청 단기예보를 서버에서 호출해 일별 강수량으로 합산하고 침수 확률을 계산한다.",
        "operationId": "flood_week_api_forecast_flood_week_get",
        "parameters": [
          {
            "name": "adm_cd",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "description": "10자리 법정동코드",
              "title": "Adm Cd"
            },
            "description": "10자리 법정동코드"
          },
          {
            "name": "building_type",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "enum": [
                    "residential",
                    "commercial",
                    "industrial",
                    "underground",
                    "road",
                    "etc"
                  ],
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "예약 필드. 현재 모델 미사용.",
              "title": "Building Type"
            },
            "description": "예약 필드. 현재 모델 미사용."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FloodWeekForecastResponse"
                }
              }
            }
          },
          "404": {
            "description": "커버리지 밖",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "기상청 호출 실패",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "기상청 키 미설정",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/weather/asos-monthly": {
      "get": {
        "tags": [
          "weather"
        ],
        "summary": "월간 ASOS 일강수량(캘린더 과거 실측)",
        "description": "기상청 ASOS 일자료를 서버에서 호출해 일별 강수량(mm)을 돌려준다(웹 CORS 회피).",
        "operationId": "asos_monthly_api_weather_asos_monthly_get",
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "maximum": 2100,
              "minimum": 2000,
              "description": "연도",
              "title": "Year"
            },
            "description": "연도"
          },
          {
            "name": "month",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "maximum": 12,
              "minimum": 1,
              "description": "월",
              "title": "Month"
            },
            "description": "월"
          },
          {
            "name": "stn",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "관측소 번호(108=서울)",
              "default": "108",
              "title": "Stn"
            },
            "description": "관측소 번호(108=서울)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsosMonthlyResponse"
                }
              }
            }
          },
          "502": {
            "description": "기상청 호출 실패",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "기상청 키 미설정",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/weather/warning-bulletin": {
      "get": {
        "tags": [
          "weather"
        ],
        "summary": "기상특보 통보문(알림 탭)",
        "description": "기상특보 최신 통보문 전문을 서버에서 호출해 돌려준다(지역 매칭은 클라이언트가 수행).",
        "operationId": "warning_bulletin_api_weather_warning_bulletin_get",
        "parameters": [
          {
            "name": "stn",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "특보구역(109=서울지방기상청)",
              "default": "109",
              "title": "Stn"
            },
            "description": "특보구역(109=서울지방기상청)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WarningBulletinResponse"
                }
              }
            }
          },
          "502": {
            "description": "기상청 호출 실패",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "기상청 키 미설정",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/dongs": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "커버리지 동 목록",
        "description": "예측 가능한 93개 법정동 (adm_cd, 구, 동) 목록 — 클라이언트 자동완성/선택 UI용",
        "operationId": "dongs_api_dongs_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AsosMonthlyResponse": {
        "properties": {
          "year": {
            "type": "integer",
            "title": "Year"
          },
          "month": {
            "type": "integer",
            "title": "Month"
          },
          "stn": {
            "type": "string",
            "title": "Stn",
            "description": "관측소(108=서울)",
            "examples": [
              "108"
            ]
          },
          "rain_by_day": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Rain By Day",
            "description": "일(1~31) → 일강수량(mm). 관측 없으면 0.0",
            "examples": [
              {
                "1": 0.0,
                "2": 12.5
              }
            ]
          },
          "source": {
            "type": "string",
            "title": "Source",
            "default": "kma_asos"
          }
        },
        "type": "object",
        "required": [
          "year",
          "month",
          "stn",
          "rain_by_day"
        ],
        "title": "AsosMonthlyResponse"
      },
      "ErrorResponse": {
        "properties": {
          "detail": {
            "type": "string",
            "title": "Detail"
          }
        },
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "ErrorResponse"
      },
      "FloodForecastDay": {
        "properties": {
          "date": {
            "type": "string",
            "title": "Date",
            "examples": [
              "2026-06-24"
            ]
          },
          "rain_mm": {
            "type": "number",
            "minimum": 0.0,
            "title": "Rain Mm",
            "description": "해당일 예보 강수량 합계(mm)",
            "examples": [
              42.5
            ]
          },
          "flood_probability": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Flood Probability",
            "examples": [
              0.0765
            ]
          },
          "risk_level": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "info",
                  "warning",
                  "danger"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Risk Level",
            "examples": [
              "warning"
            ]
          },
          "risk_percentile": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 100.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Risk Percentile",
            "examples": [
              88
            ]
          }
        },
        "type": "object",
        "required": [
          "date",
          "rain_mm",
          "flood_probability"
        ],
        "title": "FloodForecastDay"
      },
      "FloodWeekForecastResponse": {
        "properties": {
          "adm_cd": {
            "type": "integer",
            "title": "Adm Cd"
          },
          "gu": {
            "type": "string",
            "title": "Gu"
          },
          "dong": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dong"
          },
          "days": {
            "items": {
              "$ref": "#/components/schemas/FloodForecastDay"
            },
            "type": "array",
            "title": "Days"
          },
          "peak": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/FloodForecastDay"
              },
              {
                "type": "null"
              }
            ]
          },
          "source": {
            "type": "string",
            "title": "Source",
            "default": "kma_vilage_fcst"
          },
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail"
          }
        },
        "type": "object",
        "required": [
          "adm_cd",
          "gu",
          "dong",
          "days",
          "peak"
        ],
        "title": "FloodWeekForecastResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "examples": [
              "ok"
            ]
          },
          "dongs": {
            "type": "integer",
            "title": "Dongs",
            "description": "커버리지 동 수",
            "examples": [
              93
            ]
          },
          "features": {
            "type": "integer",
            "title": "Features",
            "examples": [
              16
            ]
          }
        },
        "type": "object",
        "required": [
          "status",
          "dongs",
          "features"
        ],
        "title": "HealthResponse"
      },
      "PredictRequest": {
        "properties": {
          "address": {
            "type": "string",
            "title": "Address",
            "description": "유저 주소. 지오코딩→법정동. adm_cd를 직접 주면 비워도 됨.",
            "default": "",
            "examples": [
              "서울 노원구 중계동 23-28"
            ]
          },
          "forecast_daily_rain": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "maxItems": 30,
            "minItems": 1,
            "title": "Forecast Daily Rain",
            "description": "일강우(mm) 시퀀스. 과거→오늘 순서(오늘이 마지막). 최대 30개.",
            "examples": [
              [
                5,
                40,
                60,
                100
              ]
            ]
          },
          "adm_cd": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Adm Cd",
            "description": "10자리 법정동코드. 주면 지오코딩을 건너뜀.",
            "examples": [
              1135010600
            ]
          },
          "building_type": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "residential",
                  "commercial",
                  "industrial",
                  "underground",
                  "road",
                  "etc"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Building Type",
            "description": "(선택) 건물 유형. 허용값: residential(주거)·commercial(상가/시설)·industrial(공장)·underground(지하/반지하)·road(도로)·etc(기타). 현재 모델은 사용하지 않으며 안 보내도 됨 — 향후 확장용 예약 필드.",
            "examples": [
              "residential"
            ]
          }
        },
        "type": "object",
        "required": [
          "forecast_daily_rain"
        ],
        "title": "PredictRequest",
        "examples": [
          {
            "address": "서울 노원구 중계동 23-28",
            "forecast_daily_rain": [
              5,
              40,
              60,
              100
            ]
          },
          {
            "address": "",
            "adm_cd": 1135010600,
            "forecast_daily_rain": [
              10,
              30,
              80
            ]
          }
        ]
      },
      "PredictResponse": {
        "properties": {
          "adm_cd": {
            "type": "integer",
            "title": "Adm Cd",
            "description": "법정동코드",
            "examples": [
              1135010600
            ]
          },
          "gu": {
            "type": "string",
            "title": "Gu",
            "examples": [
              "노원구"
            ]
          },
          "dong": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dong",
            "description": "동 라벨(없을 수 있음)",
            "examples": [
              "중계동"
            ]
          },
          "flood_probability": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Flood Probability",
            "description": "침수 확률 [0,1] (isotonic 보정값)",
            "examples": [
              0.7473
            ]
          },
          "risk_level": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "info",
                  "warning",
                  "danger"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Risk Level",
            "description": "상대 위험등급: info(관심)·warning(주의)·danger(경고). 보정확률은 폭우일에도 낮으므로(현실 반영) 절대%가 아닌 학습분포 백분위 기준 등급을 함께 제공. cut: warning=상위15%, danger=상위1%.",
            "examples": [
              "warning"
            ]
          },
          "risk_percentile": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 100.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Risk Percentile",
            "description": "이 예측이 학습 예측분포에서 차지하는 백분위(0-100). 높을수록 상대적 고위험.",
            "examples": [
              88
            ]
          }
        },
        "type": "object",
        "required": [
          "adm_cd",
          "gu",
          "flood_probability"
        ],
        "title": "PredictResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "WarningBulletinResponse": {
        "properties": {
          "bulletin": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bulletin",
            "description": "특보 통보문 전문(t6). 없으면 null"
          },
          "tm_fc": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tm Fc",
            "description": "발표시각(yyyyMMddHHmm)"
          },
          "has_warning": {
            "type": "boolean",
            "title": "Has Warning",
            "description": "발효 통보문 존재 여부",
            "default": false
          },
          "source": {
            "type": "string",
            "title": "Source",
            "default": "kma_wrn"
          }
        },
        "type": "object",
        "title": "WarningBulletinResponse"
      }
    }
  }
}